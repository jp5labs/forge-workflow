# JP5 Agentic Bot Fleet — Bot Identity Configuration
# ===================================================
# Copy this file for each bot:
#   cp bot.env.example marcus.env
#   cp bot.env.example alex.env
#   cp bot.env.example steph.env
#
# The .env files are gitignored — secrets are never committed.

# Bot identity
BOT_NAME=<bot-name>
GIT_USER_NAME="<Display Name> (bot)"
GIT_USER_EMAIL="<bot>@example.com"
TAILSCALE_HOSTNAME="claude-<bot-name>"

# Discord webhook for notifications (shared or bot-specific)
# Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# Discord bot token for multi-lane notifications (per-bot)
# Developer Portal → Applications → Bot → Token
DISCORD_BOT_TOKEN=

# Autonomous mode configuration
# CLAUDE_MODE: autonomous (default) or supervised
# autonomous = bypassPermissions + circuit breakers (unattended)
# supervised = acceptEdits + full hook set (today's behavior)
CLAUDE_MODE=autonomous

# Circuit breaker: consecutive failure limit (default: 5)
CB_FAILURE_LIMIT=5

# Circuit breaker: token ceiling (reserved, not yet implemented)
# CB_TOKEN_CEILING=200000
